#!/bin/sh
# {{ ansible_managed }}
# Encrypt a string as an Ansible Vault variable.
# Usage: ansible-vault-secret <variable_name> <value>

set -eu

VAULT_CLIENT="/usr/local/bin/ansible-vault-client"

if [ $# -ne 2 ]; then
  echo "Usage: ansible-vault-secret <variable_name> <value>" >&2
  exit 1
fi

VARIABLE_NAME="$1"
VALUE="$2"

if ! command -v ansible-vault >/dev/null 2>&1; then
  echo "ERROR: 'ansible-vault' is not installed" >&2
  exit 1
fi

if [ ! -x "$VAULT_CLIENT" ]; then
  echo "ERROR: Vault client not found at $VAULT_CLIENT" >&2
  exit 1
fi

printf '%s' "$VALUE" | ansible-vault encrypt_string \
  --vault-id "scbitworx@${VAULT_CLIENT}" \
  --stdin-name "$VARIABLE_NAME"
